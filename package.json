{
  "name": "AlgoHaven",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter='./apps/*'",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "zen:generate": "zen generate --schema packages/db/zenstack/schema.zmodel --output packages/db/generated/zenstack",
    "zen:db:push": "zen db push --schema packages/db/zenstack/schema.zmodel"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@zenstackhq/cli": "^3.4.3",
    "dotenv": "^17.3.1",
    "pg": "^8.19.0",
    "prettier": "^3.7.4",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@zenstackhq/orm": "^3.4.3",
    "@zenstackhq/schema": "^3.4.3"
  }
}
