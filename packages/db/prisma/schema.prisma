// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// Database connection configuration
datasource db {
  provider = "postgresql"
}

// User roles: regular user or admin
enum Role {
  USER
  ADMIN
}

// Problem difficulty levels
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// Contest visibility options
enum ContestVisibility {
  PUBLIC
  INVITE
  PRIVATE
}

// Submission status codes for judging
enum SubmissionStatus {
  QUEUED
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TLE // Time Limit Exceeded
  MLE // Memory Limit Exceeded
  RUNTIME_ERROR
  COMPILE_ERROR
}

// Judge phases for contest/practice
// Phase 1 = run against ~10% test cases during contest (fast feedback)
// Phase 2 = run against all test cases post-deadline (official result)
enum JudgePhase {
  PRACTICE
  CONTEST_PHASE1  //public TestCases during contest
  CONTEST_PHASE2  //hidden TestCases after contest
}

// Plagiarism report status
enum PlagiarismStatus {
  PENDING
  CONFIRMED
  REJECTED
}

// Rejudge job status
enum RejudgeStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// User represents a platform participant (admin or regular user)
model User {
  id          String  @id @default(uuid())
  email       String  @unique
  passwordHash String? // null if using magic link only
  role        Role    @default(USER)
  username    String? @unique

  submissions        Submission[]
  leaderboardEntries LeaderboardEntry[]
  sessions           Session[]
  ratings            UserRating[]
  rejudgesTriggered  RejudgeJob[]       @relation("triggeredBy")
  plagiarismReviews  PlagiarismReport[] @relation("reviewedBy")

  createdAt DateTime @default(now())
}

// Session tracks user login sessions
model Session {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

//  Storing Individual Problems
// Problems are created by admins/setters and can be used in multiple contests.
// After a contest ends, problems typically become visible in the public problem set.
model Problem {
  id         String     @id @default(uuid())
  title      String
  slug       String     @unique
  difficulty Difficulty @default(MEDIUM)

  // Statement — notionDocId is kept for MVP; move to `statement` field later
  notionDocId String?
  statement   String // markdown, populated once migrated off Notion

  editorial String? // markdown, published after contest ends
  tags      String[] // e.g. ["dp", "graphs", "binary-search"]

  // Execution limits
  timeLimitMs   Int @default(2000) // base limit; per-language multipliers applied at runtime
  memoryLimitKb Int @default(262144) // 256 MB default

  // Custom checker for problems with multiple valid outputs
  hasCustomChecker Boolean @default(false)
  checkerCode      String? // judge-side checker script

  isPublic Boolean @default(false) // false = only visible inside a contest

  testCases   TestCase[]
  submissions Submission[]
  contests    ContestProblem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TestCase stores input/output pairs for a Challenge.
// Used for judging submissions and showing samples to users.
model TestCase {
  id             String  @id @default(uuid())
  problemId    String
  input          String
  expectedOutput String
  isSample       Boolean @default(false) // true = shown to user; false = hidden
  points         Int     @default(0) // for partial/subtask scoring

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
}

// Contests represents a coding competition event.
// Contains metadata, timing, visibility, and links to problems and leaderboard.
model Contest {
  id         String            @id @default(uuid())
  title      String
  slug       String            @unique
  startTime  DateTime
  endTime    DateTime
  visibility ContestVisibility @default(PUBLIC)
  isRated    Boolean           @default(false)

  // Leaderboard freeze: hide rankings after this time until contest ends
  // null = no freeze
  freezeTime DateTime?

  // Practice mode: problems visible but no leaderboard/rating effect
  isPractice Boolean @default(false)

  registrationOpen Boolean @default(true)

  problems      ContestProblem[]
  submissions   Submission[]
  leaderboard   LeaderboardEntry[]
  announcements ContestAnnouncement[]
  ratings       UserRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// maps a Problem to a specific Contest.
// Defines the order and points for the problem in that contest.
// When a contest is created, problems are linked via ContestProblem.
// After the contest ends, the linked Problem can be shown in the public problem set.
model ContestProblem {
  id          String @id @default(uuid())
  contestId   String
  problemId   String
  index       Int // display order: A, B, C, D...
  points      Int // per-contest point value (overrides challenge.maxPoints)

  contest   Contest   @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([contestId, problemId])
  @@unique([contestId, index])
}

// ContestAnnouncement stores messages for contest participants.
model ContestAnnouncement {
  id        String   @id @default(uuid())
  contestId String
  message   String
  createdAt DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
}

// Submissions represents a user's solution attempt for a Problem (optionally in a Contest).
// Tracks code, language, status, scoring, and judge output.
model Submission {
  id          String  @id @default(uuid())
  userId      String
  problemId String
  contestId   String?

  code       String
  language   String // e.g. "python", "cpp", "java", "javascript"
  status     SubmissionStatus
  judgePhase JudgePhase       @default(PRACTICE)

  // Scoring
  points        Int @default(0)
  wrongAttempts Int @default(0) // cumulative wrong attempts before AC on this problem

  // Performance
  executionTimeMs Float?
  memoryUsedKb    Float?

  // Compiler / judge output
  compilerOutput String? // CE message
  judgeOutput    String? // partial stderr for RE/TLE

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([problemId])
  @@index([contestId])
  @@index([createdAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt])

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  contest   Contest?  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  plagiarismReports PlagiarismReport[]
}

// Leaderboard - tracks user scores and ranks in a Contest
model LeaderboardEntry {
  id        String @id @default(uuid())
  contestId String
  userId    String

  totalPoints  Int       @default(0)
  solved       Int       @default(0)
  penaltyMins  Int       @default(0) // total penalty minutes from wrong attempts
  lastSolvedAt DateTime? // timestamp of last AC — used as tie-breaker
  rank         Int? // materialised rank, updated after each submission

  isFrozen Boolean @default(false) // true during leaderboard freeze window

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
  @@index([contestId, totalPoints, penaltyMins]) // composite index for ranking queries
}

// Ratings- UserRating stores rating changes for a user after a Contest.
model UserRating {
  id           String   @id @default(uuid())
  userId       String
  contestId    String
  ratingBefore Int
  ratingAfter  Int
  rank         Int // final rank in that contest
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([userId])
}

// PlagiarismReport tracks suspected plagiarism between submissions.
model PlagiarismReport {
  id              String           @id @default(uuid())
  submissionId    String
  matchedWithId   String? // the other submission it was compared against
  similarityScore Float
  status          PlagiarismStatus @default(PENDING)

  reviewedById String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("reviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([status])
}

// RejudgeJob manages rejudging tasks for problems or contests.
model RejudgeJob {
  id            String        @id @default(uuid())
  problemId   String // which problem to rejudge
  contestId     String? // scope to a specific contest, or null = all submissions
  triggeredById String
  status        RejudgeStatus @default(PENDING)
  totalCount    Int           @default(0)
  doneCount     Int           @default(0)
  errorLog      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  triggeredBy User @relation("triggeredBy", fields: [triggeredById], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([status])
}
