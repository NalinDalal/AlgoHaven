{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/packages/db": ["../../packages/db/index.ts"],
      "@/packages/auth": ["../../packages/auth/index.ts"],
      "@/packages/utils/*": ["../../packages/utils/*"],
      "@algohaven/utils": ["../../packages/utils/index.ts"],
      "@algohaven/utils/*": ["../../packages/utils/*"],
      "@algohaven/db": ["../../packages/db/index.ts"],
      "@algohaven/redis": ["../../packages/redis/index.ts"],
      "@algohaven/auth": ["../../packages/auth/index.ts"]
    },

    // Best practices
    "strict": false,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitAny": false
  }
}
