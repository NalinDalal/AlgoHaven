DATABASE_URL="postgresql://postgres:postgres@localhost:5432/algohaven"
BE_PORT="3001"
BE_URL="http://localhost:{BE_PORT}"
NEXT_PUBLIC_BE_URL="http://localhost:3001"
APP_URL="http://localhost:3000"
SESSION_COOKIE_NAME="algohaven_session"
MAGIC_LINK_TTL_MS="900000"
